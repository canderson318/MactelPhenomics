not_nhos_pats <- d$patID[!d$NHOSENR & !is.na(d$NHOSENR) ] %>%
unique()
d$NHOSENR[d$patID%in% not_nhos_pats] %>% unique() # good if only FALSE
# do these patients have longitudinality
d %>%
filter(patID %in% not_nhos_pats)
# do these patients have longitudinality
d %>%
filter(patID %in% not_nhos_pats) %>%
group_by(patID, eye_num) %>%
summarize(num_visits = n_distinct(visitID))
d[, c("month", "visitID")]
d[, c("month", "visitID")] %>% unique()
# do these patients have longitudinality
d %>%
filter(patID %in% not_nhos_pats) %>%
group_by(patID, eye_num) %>%
summarize(num_visits = n_distinct(visitID))
# do these patients have longitudinality
d %>%
filter(patID %in% not_nhos_pats) %>%
group_by(patID, eye_num) %>%
summarize(num_visits = n_distinct(visitID),
longitudinal = n_distinct(visitID) > 1
)
d %>%
filter(patID %in% not_nhos_pats) %>%
group_by(patID, eye_num) %>%
reframe(num_visits = n_distinct(visitID),
longitudinal = n_distinct(visitID) > 1
)
# do these patients have longitudinality
d %>%
filter(patID %in% not_nhos_pats) %>%
group_by(patID, eye_num) %>%
reframe(num_visits = n_distinct(visitID),
longitudinal = n_distinct(visitID) > 1
) %>%
reframe(num_longitudinal = sum(longitudinal))
raw$ENR %>% names()
