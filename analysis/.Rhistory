# Chunk 3
wd_path = "/Users/christiananderson/Library/CloudStorage/OneDrive-LowyMedicalResearchInstitute/Database_EDA/analysis_versions/version012/"
# raw list of dfs
raw <- readRDS(paste0(wd_path, "processed_data/dfs_list_02.rds"))
# joined cleaned joined data
data_name <- "CF_FFA_DEM_DIAGNOSIS_ENR_FAFGRADE_FAMSTATUS_MH_OCTMAIN_OCTMTCIRRUS_OCTMTSPECTRALIS_OCTMTSTRATUS_VAA_06.rds"
d_raw <- readRDS(paste0(wd_path, "processed_data/", data_name))# clean data with everything
# grading nomenclature and information
path <- paste0(wd_path, "processed_data/database_grading_key_04.xlsx")
info <- read.xlsx(path)
# Chunk 4
path <- paste0(wd_path, "results/function_structure/")
if(!dir.exists(path)) {
dir.create(path, recursive = TRUE)
}
factors_over_time_path <- paste0(wd_path, "results/function_structure/factors_over_time/")
if(!dir.exists(factors_over_time_path)) {
dir.create(factors_over_time_path, recursive = TRUE)
}
path <- paste0(wd_path, "results/function_structure/modeling/")
if(!dir.exists(path)) {
dir.create(path, recursive = TRUE)
}
VA_modeling_path <- paste0(wd_path, "results/function_structure/modeling/VA/")
if(!dir.exists(VA_modeling_path)) {
dir.create(VA_modeling_path, recursive = TRUE)
}
MT_modeling_path <- paste0(wd_path, "results/function_structure/modeling/MT/")
if(!dir.exists(MT_modeling_path)) {
dir.create(MT_modeling_path, recursive = TRUE)
}
# Chunk 5
d <- d_raw
# remove date columns
d <- d %>%
select(-(grep("DT", names(d_raw), value = TRUE) %>%
grep("SCANDT_new", invert = TRUE, ., value = TRUE))
)
#
# # remove stratus and cirrus
# d <- d %>%
#   select(-grep("cirrus|stratus", names(d), value = TRUE, ignore.case = TRUE))
# remove text columns
d <- d %>%
select(-grep("text|manref", names(d), ignore.case = TRUE, value = TRUE))
# remove image quality/type vars
d <- d %>%
select(-grep("qual|scan_type", names(d), ignore.case = TRUE, value = TRUE))
# what's removed
# setdiff(names(d_raw), names(d))
# Chunk 6
d <- d %>%
filter(DIAGNOSIS_binary== 1)
# Chunk 7
# list of dfs with study ID and NHOSENR fields from dfs
study_ids <- sapply(raw, function(df) {
study_cols <- df %>%
select(patientId,visitId, matches("STUD|stud|NHOSENR")) %>%
unique()
return(study_cols)
})
# joino all together
df_studyIDs <- study_ids %>%
purrr::reduce(., full_join)
df_studyIDs %>% na.omit() %>% select(NHOSENR, STUDYID) %>% unique()
# NHOSENR STUDYID
# No       NHOR/S
# Yes      NHOR/S
# No       CNF
# No       SAFE
# Yes      CNF
## ^ NHOSENR no for SAFE therefore if NHOSENR missing for SAFE patients make NHOSENR "No"?
# is NHOSENR missing where studyID == "SAFE"
df_studyIDs %>%
filter( STUDYID == "SAFE")
# ^ only one patient so pointless
# what number of each value (NA to na so I can count it)
d$NHOSENR_old %>% table(., useNA = "ifany")
# Chunk 1
# dev.off()  # Turn off the current graphics device
# options(device = "RStudioGD")
# quartz()
# Chunk 2
